# NAVER CLOUD SENS 문자 발송용 환경변수
# Vercel Project Settings > Environment Variables에 동일한 이름으로 등록하세요.
NAVER_CLOUD_ACCESS_KEY=your_naver_cloud_access_key
NAVER_CLOUD_SECRET_KEY=your_naver_cloud_secret_key
NAVER_SENS_SERVICE_ID=ncp:sms:kr:000000000000:munae
NAVER_SENS_FROM=01012345678

# 선택: 실제 배포 도메인을 넣으면 브라우저 Origin을 1차로 제한합니다.
# 예: https://munae-filmfest.vercel.app
ALLOWED_ORIGIN=

# true로 두면 실제 발송하지 않고 성공 응답만 테스트합니다.
# 실운영 전에는 false로 바꾸거나 삭제하세요.
SMS_DRY_RUN=true

# v99 Supabase 원본 DB 설정
# Supabase Project Settings > API 에서 확인합니다.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
# 중요: 이 값은 Vercel 환경변수에만 넣고, 브라우저 코드에는 절대 넣지 않습니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Supabase 저장 성공 후 현재 구글시트 구조로 실시간 백업할 Apps Script /exec URL
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwc18Y1SArlzYkXfnw1so5SsFKUMg3v9-RgJagkvgihNgEqRuS-eJtM7fKpMfgqrnyE/exec
