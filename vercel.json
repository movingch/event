{
  "functions": {
    "api/send-sms.js": { "maxDuration": 10 },
    "api/google-drive-sync.js": { "maxDuration": 60 },
    "api/supabase-state.js": { "maxDuration": 60 },
    "api/supabase-google-backup.js": { "maxDuration": 60 },
    "api/survey.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/adminor", "destination": "/index.html" }
  ]
}
